#include <iostream>
#include <stack>
#include <string>
#include <cctype>
#include <stdexcept>

using namespace std;

// 定义运算符优先级
int getPrecedence(char op) {
    if (op == '+' || op == '-') return 1;
    if (op == '*' || op == '/') return 2;
    return 0;
}

// 执行基础运算，添加异常处理
double applyOp(double a, double b, char op) {
    switch (op) {
        case '+': return a + b;
        case '-': return a - b;
        case '*': return a * b;
        case '/': 
            if (b == 0) throw invalid_argument("除数不能为0");
            return a / b;
        default: throw invalid_argument("无效的运算符");
    }
}

// 解析数字（支持负数和小数）
double parseNumber(const string& tokens, int& i) {
    double val = 0.0;
    bool negative = false;
    bool hasDecimal = false;
    double decimalFactor = 0.1;

    // 处理负号
    if (tokens[i] == '-' && (i == 0 || !isdigit(tokens[i-1]) && tokens[i-1] != ')')) {
        negative = true;
        i++;
    }

    // 处理整数部分
    while (i < tokens.length() && isdigit(tokens[i])) {
        val = val * 10 + (tokens[i] - '0');
        i++;
    }

    // 处理小数部分
    if (i < tokens.length() && tokens[i] == '.') {
        hasDecimal = true;
        i++;
        while (i < tokens.length() && isdigit(tokens[i])) {
            val += (tokens[i] - '0') * decimalFactor;
            decimalFactor *= 0.1;
            i++;
        }
        if (!hasDecimal) {
            throw invalid_argument("小数点后必须有数字");
        }
    }

    i--; // 抵消外层循环的i++
    return negative ? -val : val;
}

// 检查括号是否匹配
bool checkParentheses(const string& expr) {
    stack<char> s;
    for (char c : expr) {
        if (c == '(') {
            s.push(c);
        } else if (c == ')') {
            if (s.empty()) return false;
            s.pop();
        }
    }
    return s.empty();
}

// 验证输入表达式合法性
bool isValidExpression(const string& expr) {
    if (expr.empty()) return false;
    for (char c : expr) {
        if (!isdigit(c) && c != '+' && c != '-' && c != '*' && c != '/' && c != '(' && c != ')' && c != '.' && !isspace(c)) {
            return false;
        }
    }
    return true;
}

// 表达式求值主函数
double evaluate(string tokens) {
    stack<double> values;    // 操作数栈（支持小数）
    stack<char> ops;        // 运算符栈

    for (int i = 0; i < tokens.length(); i++) {
        // 跳过空格
        if (isspace(tokens[i])) continue;

        // 处理数字（支持负数和小数）
        if (isdigit(tokens[i]) || (tokens[i] == '-' && (i == 0 || tokens[i-1] == '(' || isoperator(tokens[i-1])))) {
            try {
                double val = parseNumber(tokens, i);
                values.push(val);
            } catch (const invalid_argument& e) {
                throw runtime_error("数字解析错误: " + string(e.what()));
            }
        }
        // 处理左括号
        else if (tokens[i] == '(') {
            ops.push(tokens[i]);
        }
        // 处理右括号：计算括号内的表达式
        else if (tokens[i] == ')') {
            while (!ops.empty() && ops.top() != '(') {
                if (values.size() < 2) throw runtime_error("无效的表达式: 操作数不足");
                double val2 = values.top(); values.pop();
                double val1 = values.top(); values.pop();
                char op = ops.top(); ops.pop();
                values.push(applyOp(val1, val2, op));
            }
            if (ops.empty()) throw runtime_error("不匹配的括号");
            ops.pop(); // 弹出左括号
        }
        // 处理运算符
        else if (tokens[i] == '+' || tokens[i] == '-' || tokens[i] == '*' || tokens[i] == '/') {
            // 当前运算符与栈顶运算符比较优先级，优先级高的先计算
            while (!ops.empty() && ops.top() != '(' && getPrecedence(ops.top()) >= getPrecedence(tokens[i])) {
                if (values.size() < 2) throw runtime_error("无效的表达式: 操作数不足");
                double val2 = values.top(); values.pop();
                double val1 = values.top(); values.pop();
                char op = ops.top(); ops.pop();
                values.push(applyOp(val1, val2, op));
            }
            ops.push(tokens[i]);
        }
        else {
            throw runtime_error("无效字符: " + string(1, tokens[i]));
        }
    }

    // 处理剩余的运算符
    while (!ops.empty()) {
        if (ops.top() == '(') throw runtime_error("不匹配的括号");
        if (values.size() < 2) throw runtime_error("无效的表达式: 操作数不足");
        double val2 = values.top(); values.pop();
        double val1 = values.top(); values.pop();
        char op = ops.top(); ops.pop();
        values.push(applyOp(val1, val2, op));
    }

    if (values.size() != 1) throw runtime_error("无效的表达式: 操作数过多");
    return values.top();
}

int main() {
    string expression;
    cout << "请输入表达式: ";
    getline(cin, expression);

    try {
        // 验证输入合法性
        if (!isValidExpression(expression)) {
            throw runtime_error("无效的表达式: 包含非法字符");
        }
        if (!checkParentheses(expression)) {
            throw runtime_error("括号不匹配");
        }

        double result = evaluate(expression);
        cout << "计算结果: " << result << endl;
